@startuml

skinparam packageStyle rectangle
left to right direction

actor "User" as user
actor "Git Repository\n(Github/Gitlab)" as git

rectangle "Basic Caluclator System(main.sh)" {
	usecase "execute calc-system" as main

	usecase "input number of term \n(control 1-3, exit if input 0)" as term
	usecase "Invalid input. input number of term again" as re_term

	
	usecase "input digits" as digit
	usecase "Invalid input. input digit again" as re_digit
	
	usecase "select a basic arithmetic operation\n(1:add, 2:sub, 3:mul, 4:div, 0:exit)" as arith
	usecase "Invalid input. choose a operation again." as re_arith	
	
	usecase "manage and save log\n(switch test/prod via. env)" as log
	
	usecase "hide log path(.env)" as git_hide
}

user --> main
main --> arith : << include >>
arith --> term : << include >>
arith --> digit: << include >>
main --> log: << include >>

re_term --> term : << extend >> (if input is not 0-3)
re_digit --> digit: << extend >> (if input is not number)
re_arith --> arith : << extend >> (if input is not 0-4)


git --> git_hide

@enduml
